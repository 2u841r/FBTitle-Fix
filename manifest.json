{
  "manifest_version": 3,
  "name": "FBTitle Fix",
  "version": "1.0.0",
  "description": "Replaces generic 'Facebook' tab title with the actual page/group name",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "fbtitlefix@2u841r",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [],
        "optional": []
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.facebook.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
